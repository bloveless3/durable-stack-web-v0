{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "content/**/*.md",
          "content/**/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "content/**/*"
        ],
        "exclude": [
          "**/*.md",
          "**/toc.yml"
        ]
      }
    ],
    "globalMetadata": {
      "_appTitle": "DurableStack Docs",
      "_appName": "DurableStack Docs",
      "_enableSearch": true,
      "_disableContribution": true,
      "_disableNavbar": false,
      "_disableBreadcrumb": false,
      "_noindex": false
    },
    "template": [
      "default"
    ],
    "dest": "_site"
  }
}
