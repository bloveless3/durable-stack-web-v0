@model DurableStack.App.Models.AppHomeViewModel
@{
    Html.AddTitleParts("Dashboard");
    Html.SetActiveMenuItem(AppMenuKeys.Dashboard);
    Html.SetShowGlobalFilters(true);

    //Html.AddBreadcrumbsPart("Reports", "/reports");
    //Html.AddBreadcrumbsPart("Worker Health");
}

@section PageControls {
    <span class="app-tooltip app-tooltip-left" data-dashboard-refresh-tooltip data-tip="Last load --">
        <button type="button" class="app-page-control-button app-page-control-button-icon" data-dashboard-refresh aria-label="Refresh dashboard data">
            <i class="fa-solid fa-rotate-right app-page-control-icon-refresh" aria-hidden="true"></i>
        </button>
    </span>
}

<section class="metrics-grid" aria-label="Dashboard KPI metrics">
    <article class="metric-card metric-card-runs">
        <p class="metric-label">Runs</p>
        <p class="metric-value" data-kpi-runs-total>--</p>
    </article>
    <article class="metric-card metric-card-success">
        <p class="metric-label">Success Rate</p>
        <p class="metric-value" data-kpi-success-rate>--</p>
    </article>
    <article class="metric-card metric-card-failure">
        <p class="metric-label">Failure Rate</p>
        <p class="metric-value" data-kpi-failure-rate>--</p>
    </article>
    <article class="metric-card metric-card-retry">
        <p class="metric-label">Retry Rate</p>
        <p class="metric-value" data-kpi-retry-rate>--</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">Active Workers</p>
        <p class="metric-value" data-kpi-active-workers>--</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">P95 Duration (ms)</p>
        <p class="metric-value" data-kpi-p95-duration>--</p>
    </article>
</section>

<section class="dashboard-layout" aria-label="Operational dashboard">
    <article class="panel-card dashboard-main-panel">
        <header class="panel-header">
            <h2>Run and heartbeat timeline</h2>
            <span class="panel-meta" data-dashboard-timeframe>--</span>
        </header>
        <div class="chart-shell" data-dashboard-chart-shell>
            <div class="runs-chart" data-runs-chart role="img" aria-label="Run activity chart"></div>
            <p class="chart-empty" data-runs-chart-empty hidden>No events in this window yet.</p>
        </div>
        <div class="chart-legend" aria-label="Chart legend">
            <span><i class="legend-swatch legend-started"></i> Started</span>
            <span><i class="legend-swatch legend-succeeded"></i> Succeeded</span>
            <span><i class="legend-swatch legend-failed"></i> Failed</span>
            <span><i class="legend-swatch legend-retried"></i> Retried</span>
            <span><i class="legend-swatch legend-heartbeats"></i> Heartbeats</span>
        </div>
    </article>

    <article class="panel-card dashboard-worker-panel">
        <header class="panel-header">
            <h2>Worker health</h2>
            <span class="panel-meta">Live by freshness</span>
        </header>
        <div class="worker-status-pill-row">
            <span class="worker-status-pill status-online">Online <strong data-worker-online-count>0</strong></span>
            <span class="worker-status-pill status-warn">Warn <strong data-worker-warn-count>0</strong></span>
            <span class="worker-status-pill status-offline">Offline <strong data-worker-offline-count>0</strong></span>
        </div>
        <div class="worker-list" data-worker-list></div>
    </article>
</section>

<section class="panel-card dashboard-failures-panel" aria-label="Recent failures">
    <header class="panel-header">
        <h2>Failure groups</h2>
        <span class="panel-meta">Top 50 grouped issues</span>
    </header>
    <div class="dashboard-failure-table-wrap">
        <table class="dashboard-failure-table">
            <thead>
                <tr>
                    <th>Count</th>
                    <th>Tenant</th>
                    <th>Job</th>
                    <th>Error</th>
                    <th>Message</th>
                    <th>Last Seen</th>
                </tr>
            </thead>
            <tbody data-failures-table-body>
                <tr>
                    <td colspan="6" class="dashboard-empty-row">Waiting for telemetry.</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script src="https://www.gstatic.com/charts/loader.js"></script>
    <script src="~/js/pages/overview-page.js" asp-append-version="true"></script>
}
