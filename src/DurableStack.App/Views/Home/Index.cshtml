@model DurableStack.App.Models.AppHomeViewModel
@{
    ViewData["Title"] = "Overview";
}

<section class="page-header">
    <p class="eyebrow">Control Plane</p>
    <h1 class="page-title">Workspace overview</h1>
    <p class="page-subtitle">Monitor ingestion health while we build user, organization, and project workflows.</p>
</section>

<section class="metrics-grid" aria-label="Health metrics">
    <article class="metric-card">
        <p class="metric-label">API Status</p>
        <p class="metric-value">@Model.ApiStatus</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">Total Events</p>
        <p class="metric-value">@(Model.TotalEvents?.ToString() ?? "N/A")</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">Failed Events</p>
        <p class="metric-value">@(Model.FailedEvents?.ToString() ?? "N/A")</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">Tenant ID</p>
        <p class="metric-value metric-value-small">@(Model.TenantId ?? "N/A")</p>
    </article>
</section>

<section class="panel-grid">
    <article class="panel-card">
        <header class="panel-header">
            <h2>Recent telemetry</h2>
            <span class="panel-meta">UTC</span>
        </header>
        <dl class="detail-list">
            <div>
                <dt>Last Event</dt>
                <dd>@(Model.LastEventAtUtc?.ToString("u") ?? "N/A")</dd>
            </div>
            <div>
                <dt>Pipeline</dt>
                <dd>Ingestion-policy enforced</dd>
            </div>
            <div>
                <dt>Payload Model</dt>
                <dd>Worker-stable contract</dd>
            </div>
        </dl>
    </article>

    <article class="panel-card">
        <header class="panel-header">
            <h2>Build next</h2>
        </header>
        <ul class="task-list">
            <li>Create organization management screens</li>
            <li>Add project setup and tenant credential rotation</li>
            <li>Connect docs search palette to marketing site index</li>
        </ul>
    </article>
</section>

@section Scripts {
    <script src="~/js/pages/overview-page.js" asp-append-version="true"></script>
}
