@model DurableStack.App.Models.AppHomeViewModel
@{
    Html.AddTitleParts("Dashboard");
    Html.SetActiveMenuItem(AppMenuKeys.Dashboard);
    Html.SetShowGlobalFilters(true);

    //Html.AddBreadcrumbsPart("Reports", "/reports");
    //Html.AddBreadcrumbsPart("Worker Health");
}

@section PageControls {
    <span class="app-tooltip app-tooltip-left" data-dashboard-refresh-tooltip data-tip="Last load --">
        <button type="button" class="app-page-control-button app-page-control-button-icon" data-dashboard-refresh aria-label="Refresh dashboard data">
            <i class="fa-solid fa-rotate-right app-page-control-icon-refresh" aria-hidden="true"></i>
        </button>
    </span>
}

<section class="metrics-grid" aria-label="Health metrics">
    <article class="metric-card">
        <p class="metric-label">Dashboard</p>
        <p class="metric-value" data-dashboard-status>@Model.DashboardStatus</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">Data Source</p>
        <p class="metric-value metric-value-small">@Model.DataSource</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">Total Events</p>
        <p class="metric-value" data-total-events>@(Model.TotalEvents?.ToString() ?? "--")</p>
    </article>
    <article class="metric-card">
        <p class="metric-label">Failed Events</p>
        <p class="metric-value" data-failed-events>@(Model.FailedEvents?.ToString() ?? "--")</p>
    </article>
</section>

<section class="panel-grid">
    <article class="panel-card">
        <header class="panel-header">
            <h2>Recent telemetry</h2>
            <span class="panel-meta">UTC</span>
        </header>
        <dl class="detail-list">
            <div>
                <dt>Last Event</dt>
                <dd data-last-event>@Model.LastEventAtUtc</dd>
            </div>
            <div>
                <dt>Refresh</dt>
                <dd>@Model.RefreshCadence (automatic)</dd>
            </div>
            <div>
                <dt>Last Query</dt>
                <dd data-last-query>@Model.LastUpdateLabel</dd>
            </div>
            <div>
                <dt>Feed State</dt>
                <dd data-dashboard-feed-state>Fresh</dd>
            </div>
        </dl>
    </article>

    <article class="panel-card">
        <header class="panel-header">
            <h2>Build next</h2>
        </header>
        <ul class="task-list">
            @foreach (var item in Model.BuildNextItems)
            {
                <li>@item</li>
            }
        </ul>
    </article>
</section>

<input type="hidden" value="@(Model.NextCursor ?? string.Empty)" data-dashboard-next-cursor />

@section Scripts {
    <script src="~/js/pages/overview-page.js" asp-append-version="true"></script>
}
