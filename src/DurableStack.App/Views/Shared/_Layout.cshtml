@using DurableStack.App.Services.Identity
@inject ICurrentUserContext CurrentUserContext
@{
    var currentUserName = CurrentUserContext.DisplayName;
    if (string.IsNullOrWhiteSpace(currentUserName) && !string.IsNullOrWhiteSpace(CurrentUserContext.Email))
    {
        currentUserName = CurrentUserContext.Email;
    }

    var currentUserEmail = CurrentUserContext.Email ?? "";
    var userPrimaryLine = "DurableStack User";
    string? userSecondaryLine = null;

    if (!string.IsNullOrWhiteSpace(currentUserName) && !string.Equals(currentUserName, currentUserEmail, StringComparison.OrdinalIgnoreCase))
    {
        userPrimaryLine = currentUserName;
        userSecondaryLine = string.IsNullOrWhiteSpace(currentUserEmail) ? null : currentUserEmail;
    }
    else if (!string.IsNullOrWhiteSpace(currentUserEmail))
    {
        userPrimaryLine = currentUserEmail;
    }

    var initials = "DU";

    if (!string.IsNullOrWhiteSpace(currentUserName))
    {
        var tokens = currentUserName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (tokens.Length >= 2)
        {
            initials = string.Concat(tokens[0][0], tokens[1][0]).ToUpperInvariant();
        }
        else if (tokens.Length == 1)
        {
            var firstToken = tokens[0];
            initials = firstToken.Length >= 2
                ? firstToken[..2].ToUpperInvariant()
                : firstToken.ToUpperInvariant();
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @Html.RenderTitleParts()
    <script>
        (function () {
            var storedTheme = localStorage.getItem("durablestack-theme");
            if (storedTheme === "dark" || storedTheme === "light") {
                document.documentElement.setAttribute("data-theme", storedTheme);
            }
        })();
    </script>
    <link rel="stylesheet" href="~/scss/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/DurableStack.App.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body class="app-body">
    <div class="app-frame" data-app-frame data-sidebar-open="false">
        <header class="app-header">
            <div class="app-header-inner">
                <button type="button" class="app-menu-toggle" aria-label="Open navigation" aria-controls="app-sidebar" aria-expanded="false" data-sidebar-open-trigger>
                    <i class="fa-solid fa-bars" aria-hidden="true"></i>
                </button>

                <a class="app-header-brand" asp-area="" asp-controller="Home" asp-action="Index">DurableStack</a>

                <div class="app-header-tools">
                    <button type="button" class="app-theme-toggle" data-theme-toggle aria-pressed="false">Theme</button>
                </div>
            </div>
        </header>

        <div class="app-workspace">
            <aside id="app-sidebar" class="app-sidebar" aria-label="Primary navigation" data-sidebar>
                <p class="sidebar-label">Navigation</p>
                <nav class="sidebar-nav" aria-label="Primary">
                    <partial name="_AppSidebarMenu" model="@Html.BuildAppMenu()" />
                </nav>

                <section class="sidebar-profile" aria-label="User profile">
                    <a class="sidebar-profile-avatar" asp-area="" asp-controller="Home" asp-action="Profile" aria-label="Open profile">@initials</a>

                    <div class="sidebar-profile-meta">
                        <a class="sidebar-profile-name" asp-area="" asp-controller="Home" asp-action="Profile">@userPrimaryLine</a>
                        @if (!string.IsNullOrWhiteSpace(userSecondaryLine))
                        {
                            <a class="sidebar-profile-email" asp-area="" asp-controller="Home" asp-action="Profile">@userSecondaryLine</a>
                        }
                        <a class="sidebar-profile-link" asp-area="" asp-controller="Home" asp-action="Profile">Profile</a>
                    </div>

                    <form method="post" asp-controller="Auth" asp-action="SignOutUser" class="sidebar-profile-signout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="sidebar-profile-signout-button" aria-label="Sign out" title="Sign out">
                            <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
                        </button>
                    </form>
                </section>
            </aside>

            <button type="button" class="app-sidebar-overlay" aria-label="Close navigation" data-sidebar-close-trigger></button>

                <div class="app-content-shell">
                @{
                    Microsoft.AspNetCore.Html.IHtmlContent? pageControls = null;

                    if (IsSectionDefined("PageControls"))
                    {
                        var originalWriter = ViewContext.Writer;
                        using var controlsWriter = new System.IO.StringWriter();

                        try
                        {
                            ViewContext.Writer = controlsWriter;
                            await RenderSectionAsync("PageControls", required: false);
                        }
                        finally
                        {
                            ViewContext.Writer = originalWriter;
                        }

                        pageControls = new Microsoft.AspNetCore.Html.HtmlString(controlsWriter.ToString());
                    }

                    var pageHeaderModel = new DurableStack.App.Models.Layout.AppPageHeaderViewModel
                    {
                        Title = Html.GetCurrentPageTitle(),
                        Breadcrumbs = Html.GetBreadcrumbsParts(),
                        PageControls = pageControls
                    };
                }
                <partial name="_AppPageHeader" model="pageHeaderModel" />

                <main role="main" class="app-main">
                    @RenderBody()
                </main>
            </div>
        </div>

        <footer class="app-footer">
            <span>&copy; @DateTime.UtcNow.Year DurableStack</span>
            <span class="footer-separator">|</span>
            <span>Operational Visibility for Durable Jobs</span>
        </footer>
    </div>
    <script src="~/js/layout/toast-center.js" asp-append-version="true"></script>
    <script src="~/js/layout/app-shell.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
