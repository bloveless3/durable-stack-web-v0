<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DurableStack.App</title>
    <link rel="stylesheet" href="~/scss/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DurableStack.App.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body class="app-body">
    <div class="app-shell">
        <header class="app-header">
            <div class="app-header-inner">
                <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark" aria-hidden="true"></span>
                    <span class="brand-text">DurableStack</span>
                    <span class="brand-surface">App</span>
                </a>

                <nav class="top-nav" aria-label="Primary">
                    <a class="top-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Overview</a>
                    <a class="top-nav-link" href="#">Organizations</a>
                    <a class="top-nav-link" href="#">Projects</a>
                    <a class="top-nav-link" href="#">Users</a>
                    <a class="top-nav-link" href="#">Billing</a>
                </nav>

                <div class="app-header-tools">
                    <button type="button" class="search-trigger" data-command-open>
                        <span class="search-icon" aria-hidden="true">&#128269;</span>
                        <span>Search</span>
                        <span class="search-shortcut">Ctrl K</span>
                    </button>
                    <form method="post" asp-controller="Auth" asp-action="SignOutUser" class="inline-flex">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="avatar-button" aria-label="Sign out">Exit</button>
                    </form>
                </div>
            </div>
        </header>

        <div class="app-grid">
            <aside class="app-sidebar" aria-label="Workspace">
                <p class="sidebar-label">Workspace</p>
                <a class="sidebar-link is-active" href="#">Dashboard</a>
                <a class="sidebar-link" href="#">My Organizations</a>
                <a class="sidebar-link" href="#">Projects</a>
                <a class="sidebar-link" href="#">API Credentials</a>
                <a class="sidebar-link" href="#">Alerts</a>
                <a class="sidebar-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </aside>

            <main role="main" class="app-main">
                @RenderBody()
            </main>
        </div>

        <footer class="app-footer">
            <span>&copy; 2026 DurableStack</span>
            <span class="footer-separator">|</span>
            <span>Operational Visibility for Durable Jobs</span>
        </footer>
    </div>

    <div class="command-overlay" data-command-overlay hidden>
        <section class="command-dialog" role="dialog" aria-modal="true" aria-label="Search DurableStack app">
            <header class="command-header">
                <span class="search-icon" aria-hidden="true">&#128269;</span>
                <input id="command-input" class="command-input" type="search" placeholder="Search organizations, projects, docs" autocomplete="off" />
                <button type="button" class="command-esc" data-command-close>esc</button>
            </header>
            <div class="command-body">
                <p class="command-muted">Jump to</p>
                <button type="button" class="command-item">Organizations</button>
                <button type="button" class="command-item">Projects</button>
                <button type="button" class="command-item">Users</button>
                <button type="button" class="command-item">API Keys</button>
                <button type="button" class="command-item">Docs Search (marketing site)</button>
            </div>
            <footer class="command-footer">
                <span>Use the same search UX for docs on <code>durablestack.com</code>.</span>
            </footer>
        </section>
    </div>

    <script src="~/js/layout/command-palette.js" asp-append-version="true"></script>
    <script src="~/js/layout/app-shell.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
