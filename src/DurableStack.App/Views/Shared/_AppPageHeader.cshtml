@model DurableStack.App.Models.Layout.AppPageHeaderViewModel
@using DurableStack.App.Extensions

@{
    var serverToasts = TempData.GetToastNotifications();
}

<section class="app-page-header" data-page-header>
    <div class="app-toast-region" data-toast-region>
        @foreach (var toast in serverToasts)
        {
            var toastType = toast.Type?.Trim().ToLowerInvariant() switch
            {
                "success" => "success",
                "error" => "error",
                "warning" => "warning",
                _ => "info"
            };

            <article class="app-toast app-toast-@toastType" data-toast data-toast-type="@toastType" data-toast-timeout="@toast.TimeoutMs">
                <div class="app-toast-body">@toast.Message</div>
                <button type="button" class="app-toast-close" data-toast-dismiss aria-label="Dismiss notification">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </button>
            </article>
        }
    </div>

    <div class="app-page-bar" aria-label="Page heading">
        <div class="app-page-bar-main">
            <h1 class="app-page-title">@Model.Title</h1>
            <nav class="app-breadcrumbs" aria-label="Breadcrumb">
                <a href="/" class="app-breadcrumb-home" aria-label="Home">
                    <i class="fa-solid fa-house" aria-hidden="true"></i>
                </a>

                @foreach (var crumb in Model.Breadcrumbs)
                {
                    <span aria-hidden="true">/</span>

                    if (!string.IsNullOrWhiteSpace(crumb.Url))
                    {
                        <a href="@crumb.Url">@crumb.Title</a>
                    }
                    else
                    {
                        <span>@crumb.Title</span>
                    }
                }
            </nav>
        </div>
        <div class="app-page-controls">
            @if (Model.ShowGlobalFilters)
            {
                <div class="app-global-filters" data-global-filters>
                    <label class="app-global-filter-field">
                        <span>Organization</span>
                        <select data-global-filter-key="global.filter.organization">
                            <option value="all-organizations" selected="@(Model.GlobalFilters.Organization == "all-organizations")">All organizations</option>
                            <option value="durablestack" selected="@(Model.GlobalFilters.Organization == "durablestack")">DurableStack</option>
                            <option value="acme-platform" selected="@(Model.GlobalFilters.Organization == "acme-platform")">Acme Platform</option>
                        </select>
                    </label>

                    <label class="app-global-filter-field">
                        <span>Project</span>
                        <select data-global-filter-key="global.filter.project">
                            <option value="all-projects" selected="@(Model.GlobalFilters.Project == "all-projects")">All projects</option>
                            <option value="platform-core" selected="@(Model.GlobalFilters.Project == "platform-core")">Platform Core</option>
                            <option value="ops-pipeline" selected="@(Model.GlobalFilters.Project == "ops-pipeline")">Ops Pipeline</option>
                        </select>
                    </label>

                    <label class="app-global-filter-field">
                        <span>Environment</span>
                        <select data-global-filter-key="global.filter.environment">
                            <option value="all-environments" selected="@(Model.GlobalFilters.Environment == "all-environments")">All environments</option>
                            <option value="prod" selected="@(Model.GlobalFilters.Environment == "prod")">Production</option>
                            <option value="staging" selected="@(Model.GlobalFilters.Environment == "staging")">Staging</option>
                            <option value="dev" selected="@(Model.GlobalFilters.Environment == "dev")">Development</option>
                        </select>
                    </label>

                    <label class="app-global-filter-field">
                        <span>Time</span>
                        <select data-global-filter-key="global.filter.timeRange">
                            <option value="1h" selected="@(Model.GlobalFilters.TimeRange == "1h")">Last hour</option>
                            <option value="24h" selected="@(Model.GlobalFilters.TimeRange == "24h")">Last 24h</option>
                            <option value="7d" selected="@(Model.GlobalFilters.TimeRange == "7d")">Last 7d</option>
                            <option value="30d" selected="@(Model.GlobalFilters.TimeRange == "30d")">Last 30d</option>
                        </select>
                    </label>
                </div>
            }

            @if (Model.PageControls is not null)
            {
                @Model.PageControls
            }
        </div>
    </div>
</section>
