@model DurableStack.App.Models.Workspace.WorkspacePageViewModel
@{
    Html.AddTitleParts(Model.Title);
    Html.SetActiveMenuItem(Model.MenuKey);
    Html.SetShowGlobalFilters(false);
    Html.AddBreadcrumbsPart("Workspace", "/");
    Html.AddBreadcrumbsPart(Model.Title);

    var pageStateModel = new DurableStack.App.Models.Layout.PageStateViewModel
    {
        Type = "empty",
        Title = "No data yet",
        Message = "This section is scaffolded and ready for real data wiring.",
        ActionText = "Go to Dashboard",
        ActionUrl = "/"
    };
}

<section class="panel-card">
    <header class="panel-header">
        <h2>@Model.Title</h2>
        <span class="panel-meta">Stub</span>
    </header>
    <p>@Model.Description</p>
</section>

<partial name="_PageState" model="pageStateModel" />
