{
  "Authentication": {
    "UserJwt": {
      "Issuer": "DurableStack.App",
      "Audience": "DurableStack.Api",
      "SigningKey": "dev-only-signing-key-change-me-please-32chars",
      "RequireHttpsMetadata": false
    }
  },
  "Documentation": {
    "BaseUrl": "https://docs.durablestack.com"
  },
  "ConnectionStrings": {
    "ControlPlane": "Host=localhost;Port=5432;Database=durablestack_control;Username=postgres;Password=Greenhilt0*",
    "Telemetry": "Host=localhost;Port=5432;Database=durablestack_telemetry;Username=postgres;Password=Greenhilt0*"
  },
  "TelemetryLifecycle": {
    "ExecutionMode": "local",
    "RollupWorker": {
      "Enabled": true,
      "IntervalMinutes": 5,
      "FinalizationLagMinutes": 60,
      "MaxBucketsPerTenantPerRun": 96,
      "BucketSizes": [ "15m", "2h", "12h" ]
    },
    "RetentionWorker": {
      "Enabled": true,
      "DryRun": false,
      "IntervalHours": 24,
      "FreeRetentionDays": 7,
      "PaidRetentionDays": 730,
      "PaidTenantPublicIds": []
    },
    "Query": {
      "EnableHybridRollupReads": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
